{
  "name": "sabzi-tracker-tests",
  "version": "1.0.0",
  "description": "Production test suite for SabziTracker — unit, integration, and E2E tests",
  "private": true,
  "scripts": {
    "test": "jest tests/unit/ --verbose",
    "test:unit": "jest tests/unit/ --verbose --coverage",
    "test:integration": "playwright test tests/integration/ --reporter=list",
    "test:e2e": "playwright test tests/e2e/ --reporter=list",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:regression": "jest tests/unit/logic.test.js --verbose --testNamePattern='R0'",
    "test:watch": "jest tests/unit/ --watch",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.43.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/unit/**/*.test.js"
    ],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "tests/unit/**/*.js"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 80,
        "branches": 80,
        "functions": 80,
        "lines": 80
      }
    }
  },
  "dependencies": {
    "sabzi-tracker-tests": "file:"
  }
}
